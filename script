);

-- 3. CREACIÓN DE LA TABLA CON RELACIONES (Foreign Keys)
CREATE TABLE leave_requests (
    id                  UUID PRIMARY KEY DEFAULT uuid_generate_v4(), -- Usa la extensión ya creada [cite: 1, 26]
    
    -- Relaciones vinculadas a tus tablas actuales [cite: 4, 5]
    user_id             UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE, 
    company_id          UUID NOT NULL REFERENCES companies(id) ON DELETE CASCADE, 
    
    leave_type          leave_type NOT NULL DEFAULT 'absence',
    leave_reason        leave_reason NOT NULL DEFAULT 'other',
    reason_note         TEXT,          
    
    start_date          DATE NOT NULL,
    end_date            DATE NOT NULL,
    
    -- Utilizamos el tipo leave_status que ya definiste previamente [cite: 26]
    status              leave_status NOT NULL DEFAULT 'pending', 
    
    -- Campos de justificante y control
    attachment_path     VARCHAR(500),  
    attachment_verified BOOLEAN NOT NULL DEFAULT FALSE,
    force_proof         BOOLEAN NOT NULL DEFAULT FALSE, 
    
    -- Relación con el revisor (Manager) [cite: 4, 29]
    reviewed_by         UUID REFERENCES users(id) ON DELETE SET NULL,          
    reviewed_at         TIMESTAMPTZ,
    review_note         TEXT,
    
    created_at          TIMESTAMPTZ DEFAULT CURRENT_TIMESTAMP,
    updated_at          TIMESTAMPTZ DEFAULT CURRENT_TIMESTAMP,

    -- Validación de coherencia de fechas [cite: 30]
    CONSTRAINT chk_dates CHECK (end_date >= start_date)
);

-- 4. LÓGICA DE NEGOCIO: RESTRICCIÓN DE JUSTIFICANTES
-- Obliga a subir archivo si el motivo lo requiere o el manager lo fuerza, 
-- pero permite el estado 'pending' sin archivo para que el empleado lo suba luego.
ALTER TABLE leave_requests
    ADD CONSTRAINT chk_requires_proof CHECK (
        (
            leave_reason NOT IN ('sick', 'maternity', 'wedding', 'bereavement', 'medical_appointment', 'legal_duty')
            AND force_proof = FALSE
        )
        OR attachment_path IS NOT NULL
        OR status = 'pending'
    );

